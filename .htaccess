# Optional: CMS push — cms-seo-sync.php reads this. Must match FRONTEND_SEO_SYNC_SECRET in Global CMS .env.
<IfModule mod_env.c>
  SetEnv CMS_SEO_SYNC_SECRET "Seosyncsecret123@"
</IfModule>

# SPA fallback with SEO prerender.
# Static files (JS, CSS, images, fonts) are served directly by Apache.
# Non-file requests go through seo-prerender.php so view-source and crawlers see CMS meta.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^$ /seo-prerender.php [L]
  RewriteRule ^index\.html$ /seo-prerender.php [L]

  RewriteCond %{REQUEST_FILENAME} -f
  RewriteCond %{REQUEST_URI} !^/?$
  RewriteCond %{REQUEST_URI} !^/index\.html$
  RewriteRule . - [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^robots\.txt$ /robots-cms.php [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^sitemap\.xml$ /sitemap-cms.php [L]

  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !^/?$
  RewriteRule . - [L]

  RewriteRule . /seo-prerender.php [L]
</IfModule>

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteRule ^_seo_cache/ - [F,L]
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>
